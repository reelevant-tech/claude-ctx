{
  "name": "claude-ctx",
  "version": "0.1.0",
  "description": "Smart context + autonomous prompt-injection layer for Claude Code: repo intelligence index, deterministic context router, MCP tools, hooks and session memory.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "ctx": "dist/cli.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ignore": "^7.0.0",
    "picomatch": "^4.0.2",
    "typescript": "^5.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/picomatch": "^4.0.0",
    "esbuild": "^0.25.0",
    "prettier": "^3.5.0",
    "vitest": "^3.1.0"
  }
}
